        </mxCell>
        <mxCell id="a3" parent="1" style="shape=step;perimeter=stepPerimeter;direction=west;html=1;whiteSpace=wrap;fontSize=9;align=center;verticalAlign=middle;spacingLeft=8;spacingRight=8;strokeColor=#000000;fillColor=#f7f7f7;size=0.12;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;A non-AI safety net using basic rules. It always&amp;nbsp;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;returns&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;a score, so no transfer goes unchecked.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
