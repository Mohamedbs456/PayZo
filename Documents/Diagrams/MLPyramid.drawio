        </mxCell>
        <mxCell id="a2" parent="1" style="shape=step;perimeter=stepPerimeter;direction=west;html=1;whiteSpace=wrap;fontSize=9;align=center;verticalAlign=middle;spacingLeft=8;spacingRight=8;strokeColor=#000000;fillColor=#f7f7f7;size=0.12;" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;A simpler secondary model. The system switches&amp;nbsp;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;to it&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;automatically if the main model is unavailable.&lt;/span&gt;&lt;/div&gt;" vertex="1">
