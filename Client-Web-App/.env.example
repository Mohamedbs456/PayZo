# Backend API base URL (Spring Boot, /api/v1 prefix included).
VITE_API_BASE_URL=http://localhost:8081/api/v1

# Backend health endpoint (Spring Actuator). Used by useHealthCheck (Impact 22).
VITE_HEALTH_URL=http://localhost:8081/actuator/health

# Keycloak realm dedicated to client (end-user) accounts.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=clients

# Public PKCE client used by the frontend. The confidential `payzo-backend`
# client (in the same realm) is reserved for the Spring backend (Keycloak
# Admin API service-account flows).
VITE_KEYCLOAK_CLIENT_ID=payzo-client-app

# Leave VITE_KEYCLOAK_CLIENT_SECRET unset for public clients. Set it only if
# you swap to a confidential client.
# VITE_KEYCLOAK_CLIENT_SECRET=
