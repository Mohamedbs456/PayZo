EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8081/api/v1
# Keycloak must be reached at the SAME host the backend validates as the token
# issuer (backend issuer-uri = http://localhost:8080/realms/clients). On the
# emulator, run `adb reverse tcp:8080 tcp:8080` and keep this as localhost so the
# minted token's `iss` matches; a 10.0.2.2 issuer is rejected by the backend.
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080
EXPO_PUBLIC_KEYCLOAK_REALM=clients
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=payzo-client-app
EXPO_PUBLIC_HEALTH_URL=http://10.0.2.2:8081/actuator/health
RCT_METRO_PORT=8083
# For a physical device on the same WiFi, swap 10.0.2.2 for your laptop's LAN IP (run `ipconfig` to find it, e.g. http://192.168.1.42:8081/api/v1)
