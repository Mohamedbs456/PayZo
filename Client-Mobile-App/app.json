{
  "expo": {
    "name": "PayZo",
    "slug": "client-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "payzo",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#f1faee",
    "newArchEnabled": true,
    "android": {
      "package": "com.payzo.client",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f1faee"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#063b4d"
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "PayZo uses the camera to scan a recipient RIB QR code.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PayZo needs access to your photos so you can set a profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1d3557"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
