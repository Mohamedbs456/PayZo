# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ─── Keycloak ─────────────────────────────────────────────────────────────────
# Keycloak bootstrap admin password (used to log in to /admin at http://localhost:8080)
KC_ADMIN_PASSWORD=changeme

# Keycloak's own DB user password (separate schema inside the same postgres instance)
KC_DB_PASSWORD=changeme

# OAuth2 client secrets — must match the secrets configured in Keycloak admin console
# for the payzo-backend client (clients realm) and payzo-backend-bo client (backoffice realm)
KC_CLIENTS_SECRET=changeme
KC_BACKOFFICE_SECRET=changeme

# ─── Email notifications (Gmail SMTP) ─────────────────────────────────────────
PAYZO_EMAIL=payzo.notifications@gmail.com
PAYZO_EMAIL_APP_PASSWORD=changeme

# ─── SMS notifications (Vonage) ───────────────────────────────────────────────
VONAGE_API_KEY=changeme
VONAGE_API_SECRET=changeme

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set ML_ENABLED=true once the trained XGBoost model is placed in ML-Service/artifacts/
ML_ENABLED=false

# Set OTP_DELIVERY_ENABLED=true in production to actually send email/SMS OTPs
OTP_DELIVERY_ENABLED=false

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Docker volume mount path inside the backend container — do not change
UPLOADS_PATH=/app/uploads
