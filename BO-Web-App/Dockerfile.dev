# Vite dev server for the backoffice frontend.
# Source is bind-mounted at /app via docker-compose; node_modules lives in a
# named volume so host/container OS differences don't collide.
FROM node:22-alpine

WORKDIR /app

# git is needed by some npm postinstall scripts.
RUN apk add --no-cache git

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5174

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
